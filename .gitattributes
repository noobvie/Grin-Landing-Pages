# Normalize line endings to LF in the repo (consistent across Windows/Mac/Linux)
* text=auto eol=lf

# Shell scripts — always LF, never CRLF (bash breaks on CRLF)
*.sh text eol=lf

# Web files — LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.conf text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.txt  text eol=lf

# Binary — never touch these
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  text eol=lf
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
